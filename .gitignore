# Dependencies
node_modules/

# Build output is intentionally tracked. Users install this plugin by
# downloading the source zip and importing manifest.json into Figma, which
# references dist/main.js + dist/ui.html. Keeping the bundles in git means
# clone-and-run works without `npm run build`. CI rebuilds dist/ on push to
# main (see .github/workflows/build-dist.yml) so the tracked bundles stay in
# sync with src/ automatically.

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Env
.env
.env.local
.env.*.local

# Test / coverage
coverage/
.nyc_output/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Scraped artifacts (regenerable via `claude-figma <url>`)
screens.json
sprout.json
walkin.json
*.scrape.json
docs/templates/
